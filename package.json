  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "chrome-remote-interface": "^0.33.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.31.14",
    "@types/node": "^22.10.0"
  }
}
